# ── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
BASE_URL=

# ── Security ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── Google OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match exactly what you registered in Google Cloud Console
GOOGLE_REDIRECT_URI=

# ── Storage ────────────────────────────────────────────────────────────────
DB_PATH=./data/collector.sqlite
DOWNLOADS_PATH=./downloads
LOGS_PATH=./logs

# ── Harvest tuning ─────────────────────────────────────────────────────────
HARVEST_CONCURRENCY=5
HARVEST_BATCH_SIZE=500
HARVEST_DELAY_MS=50